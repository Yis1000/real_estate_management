<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================ LIST ============================ -->
    <!-- decoration-danger turns the whole row RED for delinquent tenants -->
    <record id="view_contract_list" model="ir.ui.view">
        <field name="name">real.estate.contract.list</field>
        <field name="model">real.estate.contract</field>
        <field name="arch" type="xml">
            <list decoration-danger="is_overdue"
                  decoration-muted="state in ('done', 'cancelled')"
                  decoration-success="payment_state == 'paid'">
                <field name="name"/>
                <field name="property_id"/>
                <field name="tenant_id"/>
                <field name="contract_type"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="next_payment_date"/>
                <field name="amount_collected" sum="Collected"/>
                <field name="amount_overdue" sum="Overdue"
                       decoration-danger="amount_overdue &gt; 0"/>
                <field name="state" widget="badge"/>
                <field name="payment_state" widget="badge"
                       decoration-danger="payment_state == 'overdue'"
                       decoration-success="payment_state == 'paid'"
                       decoration-warning="payment_state == 'on_track'"/>
                <field name="is_overdue" column_invisible="1"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- =========================== KANBAN =========================== -->
    <record id="view_contract_kanban" model="ir.ui.view">
        <field name="name">real.estate.contract.kanban</field>
        <field name="model">real.estate.contract</field>
        <field name="arch" type="xml">
            <kanban default_group_by="payment_state">
                <field name="is_overdue"/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="oe_kanban_card #{record.is_overdue.raw_value ? 'oe_kanban_color_1' : ''}">
                            <strong class="o_kanban_record_title">
                                <field name="name"/>
                            </strong>
                            <div><field name="property_id"/></div>
                            <div class="text-muted"><field name="tenant_id"/></div>
                            <div class="mt-1">
                                Collected: <field name="amount_collected" widget="monetary"/>
                            </div>
                            <div t-if="record.is_overdue.raw_value"
                                 class="text-danger fw-bold">
                                <i class="fa fa-exclamation-triangle me-1" title="Overdue"/>
                                Overdue: <field name="amount_overdue" widget="monetary"/>
                            </div>
                            <footer>
                                <field name="state" widget="label_selection"
                                       options="{'classes': {'running': 'success', 'draft': 'muted', 'expired': 'warning', 'cancelled': 'danger'}}"/>
                                <field name="next_payment_date"/>
                            </footer>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ============================ FORM ============================ -->
    <record id="view_contract_form" model="ir.ui.view">
        <field name="name">real.estate.contract.form</field>
        <field name="model">real.estate.contract</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" type="object" string="Confirm"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_close" type="object" string="Close"
                            invisible="state != 'running'"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state in ('done', 'cancelled')"/>
                    <button name="action_set_to_draft" type="object"
                            string="Reset to Draft"
                            invisible="state not in ('cancelled', 'expired')"/>
                    <button name="%(action_report_contract)d" type="action"
                            string="Print Contract" icon="fa-print"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,running,done"/>
                </header>
                <sheet>
                    <!-- RED DELINQUENCY ALERT BANNER -->
                    <div class="alert alert-danger" role="alert"
                         invisible="not is_overdue">
                        <i class="fa fa-exclamation-triangle me-2" title="Alert"/>
                        <strong>Delinquency alert:</strong>
                        this tenant has <field name="overdue_count" class="oe_inline"/>
                        overdue collection(s) totalling
                        <field name="amount_overdue" class="oe_inline" widget="monetary"/>.
                    </div>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_payments" type="object"
                                class="oe_stat_button" icon="fa-money">
                            <field name="payment_count" widget="statinfo" string="Collections"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Contract">
                            <field name="contract_type"/>
                            <field name="property_id"/>
                            <field name="owner_id" readonly="1"/>
                            <field name="tenant_id"/>
                            <field name="agent_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Dates &amp; Amounts">
                            <field name="currency_id" invisible="1"/>
                            <field name="date_signed"/>
                            <field name="date_start"/>
                            <field name="date_end"
                                   required="contract_type == 'rent'"/>
                            <field name="payment_day"
                                   invisible="contract_type != 'rent'"/>
                            <field name="rent_amount"
                                   invisible="contract_type != 'rent'"/>
                            <field name="sale_amount"
                                   invisible="contract_type != 'sale'"/>
                            <field name="deposit"/>
                        </group>
                    </group>
                    <group string="Collection Summary" col="4">
                        <field name="payment_state" widget="badge"/>
                        <field name="next_payment_date"/>
                        <field name="amount_collected"/>
                        <field name="amount_pending"/>
                        <field name="amount_overdue"
                               decoration-danger="amount_overdue &gt; 0"/>
                        <field name="overdue_count"/>
                        <field name="is_overdue" invisible="1"/>
                    </group>
                    <notebook>
                        <page string="Collections" name="payments">
                            <field name="payment_ids">
                                <list editable="bottom"
                                      decoration-danger="state == 'overdue'"
                                      decoration-success="state == 'paid'">
                                    <field name="description"/>
                                    <field name="due_date"/>
                                    <field name="amount" sum="Total"/>
                                    <field name="payment_date"/>
                                    <field name="days_overdue"/>
                                    <field name="state" widget="badge"
                                           decoration-danger="state == 'overdue'"
                                           decoration-success="state == 'paid'"/>
                                    <field name="currency_id" column_invisible="1"/>
                                    <button name="action_register_payment" type="object"
                                            string="Register Payment" icon="fa-check"
                                            invisible="state in ('paid', 'cancelled')"/>
                                </list>
                            </field>
                        </page>
                        <page string="Legal" name="legal"
                              invisible="contract_type != 'rent'">
                            <group>
                                <group>
                                    <field name="occupants_description"
                                           placeholder="e.g. Lessee, spouse and 2 children"/>
                                </group>
                                <group>
                                    <field name="landlord_iban"
                                           placeholder="ESxx xxxx xxxx xxxx xxxx xxxx"/>
                                </group>
                            </group>
                        </page>
                        <page string="Terms &amp; Conditions" name="terms">
                            <field name="note" placeholder="Contract terms..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- =========================== SEARCH =========================== -->
    <record id="view_contract_search" model="ir.ui.view">
        <field name="name">real.estate.contract.search</field>
        <field name="model">real.estate.contract</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="property_id"/>
                <field name="tenant_id"/>
                <filter name="running" string="Running"
                        domain="[('state', '=', 'running')]"/>
                <filter name="overdue" string="Delinquent (Overdue)"
                        domain="[('is_overdue', '=', True)]"/>
                <separator/>
                <filter name="rent" string="Rentals"
                        domain="[('contract_type', '=', 'rent')]"/>
                <filter name="sale" string="Sales"
                        domain="[('contract_type', '=', 'sale')]"/>
                <group>
                    <filter name="group_state" string="Status"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_payment_state" string="Collection Status"
                            context="{'group_by': 'payment_state'}"/>
                    <filter name="group_type" string="Type"
                            context="{'group_by': 'contract_type'}"/>
                    <filter name="group_property" string="Property"
                            context="{'group_by': 'property_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ======================= GRAPH & PIVOT ======================== -->
    <record id="view_contract_graph" model="ir.ui.view">
        <field name="name">real.estate.contract.graph</field>
        <field name="model">real.estate.contract</field>
        <field name="arch" type="xml">
            <graph string="Contracts" type="bar">
                <field name="contract_type"/>
                <field name="payment_state"/>
                <field name="amount_collected" type="measure"/>
                <field name="amount_overdue" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- =========================== ACTIONS ========================== -->
    <record id="action_contract" model="ir.actions.act_window">
        <field name="name">Contracts</field>
        <field name="res_model">real.estate.contract</field>
        <field name="view_mode">list,kanban,form,graph</field>
        <field name="search_view_id" ref="view_contract_search"/>
    </record>

    <record id="action_contract_overdue" model="ir.actions.act_window">
        <field name="name">Delinquent Contracts (Morosos)</field>
        <field name="res_model">real.estate.contract</field>
        <field name="view_mode">list,kanban,form,graph</field>
        <field name="domain">[('is_overdue', '=', True)]</field>
        <field name="search_view_id" ref="view_contract_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No delinquent tenants</p>
            <p>Contracts with overdue collections appear here in red.</p>
        </field>
    </record>

</odoo>
