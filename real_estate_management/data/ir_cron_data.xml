<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Daily delinquency check: flags overdue collections and raises alerts -->
    <record id="cron_check_overdue_payments" model="ir.cron">
        <field name="name">Real Estate: Check Overdue Collections</field>
        <field name="model_id" ref="model_real_estate_payment"/>
        <field name="state">code</field>
        <field name="code">model._cron_check_overdue_payments()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>

</odoo>
