    <menuitem id="menu_directory" name="Directory"
              parent="menu_real_estate_root" sequence="60"/>
    <menuitem id="menu_partner_owner" name="Owners"
              parent="menu_directory" action="action_partner_owner" sequence="10"/>
    <menuitem id="menu_partner_tenant" name="Tenants"
