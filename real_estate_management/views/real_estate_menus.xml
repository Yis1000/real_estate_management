    <menuitem id="menu_configuration" name="Configuration"
              parent="menu_real_estate_root" sequence="90"
              groups="group_real_estate_manager"/>
    <menuitem id="menu_property_type" name="Property Types"
              parent="menu_configuration" action="action_property_type"
              sequence="10"/>

</odoo>
