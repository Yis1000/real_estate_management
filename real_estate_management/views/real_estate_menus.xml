<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================ ROOT ============================ -->
    <menuitem id="menu_real_estate_root"
              name="Real Estate"
              web_icon="real_estate_management,static/description/icon.png"
              sequence="20"
              groups="group_real_estate_user"/>

    <!-- ========================== DASHBOARD ========================= -->
    <menuitem id="menu_dashboard" name="Dashboard"
              parent="menu_real_estate_root"
              action="action_dashboard_main"
              sequence="10"/>

    <!-- ========================== PROPERTIES ======================== -->
    <menuitem id="menu_properties" name="Properties"
              parent="menu_real_estate_root" sequence="20"/>
    <menuitem id="menu_property" name="Properties"
              parent="menu_properties" action="action_property" sequence="10"/>
    <menuitem id="menu_visit" name="Visits"
              parent="menu_properties" action="action_visit" sequence="20"/>

    <!-- ========================== CONTRACTS ========================= -->
    <menuitem id="menu_contracts" name="Contracts"
              parent="menu_real_estate_root" sequence="30"/>
    <menuitem id="menu_contract" name="Contracts"
              parent="menu_contracts" action="action_contract" sequence="10"/>
    <menuitem id="menu_payment" name="Collections"
              parent="menu_contracts" action="action_payment" sequence="20"/>
