#: model_terms:ir.ui.view,arch_db:real_estate_management.report_contract_document
msgid ".\n                        The dwelling is"
msgstr ""

#. module: real_estate_management
#: model_terms:ir.ui.view,arch_db:real_estate_management.report_contract_document
msgid ".\n                        The lease shall be automatically extended for annual\n                        periods up to a maximum term of five (5) years, unless\n                        the Lessee notifies the Lessor in writing of their\n                        intention not to renew with at least thirty (30) days\n                        notice prior to the end of the agreed term or any of\n                        its annual extensions."
msgstr ".\n El arrendamiento se prorrogará automáticamente por períodos anuales hasta un plazo máximo de cinco (5) años, salvo que el arrendatario comunique al arrendador por escrito su intención de no renovarlo con una antelación mínima de treinta (30) días al cumplimiento del plazo pactado o de cualquiera de sus prórrogas anuales."

