<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================ LIST ============================ -->
    <record id="view_visit_list" model="ir.ui.view">
        <field name="name">real.estate.visit.list</field>
        <field name="model">real.estate.visit</field>
        <field name="arch" type="xml">
            <tree decoration-success="state == 'confirmed'"
                  decoration-info="state == 'scheduled'"
                  decoration-muted="state in ('done', 'cancelled')"
                  decoration-danger="state == 'no_show'">
                <field name="name"/>
                <field name="date_start"/>
                <field name="property_id"/>
                <field name="contact_id"/>
                <field name="agent_id" widget="many2one_avatar_user"/>
                <field name="visit_type"/>
                <field name="interest_level" optional="show"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>

    <!-- =========================== CALENDAR ========================= -->
    <record id="view_visit_calendar" model="ir.ui.view">
        <field name="name">real.estate.visit.calendar</field>
        <field name="model">real.estate.visit</field>
        <field name="arch" type="xml">
            <calendar string="Property Visits"
                      date_start="date_start" date_stop="date_end"
                      mode="week" color="agent_id"
                      event_open_popup="true">
                <field name="property_id" filters="1"/>
                <field name="contact_id" filters="1"/>
                <field name="agent_id" filters="1" invisible="1"/>
                <field name="state"/>
                <field name="visit_type"/>
            </calendar>
        </field>
    </record>

    <!-- =========================== KANBAN =========================== -->
    <record id="view_visit_kanban" model="ir.ui.view">
        <field name="name">real.estate.visit.kanban</field>
        <field name="model">real.estate.visit</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="color"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                        <strong class="o_kanban_record_title">
                            <field name="property_id"/>
                        </strong>
                        <div class="text-muted small">
                            <field name="name"/>
                        </div>
                        <div class="mt-1">
                            <i class="fa fa-user me-1" title="Visitor"/>
                            <field name="contact_id"/>
                        </div>
                        <div>
                            <i class="fa fa-calendar me-1" title="Date"/>
                            <field name="date_start" widget="datetime"/>
                        </div>
                        <footer>
                            <field name="visit_type" widget="label_selection"
                                   options="{'classes': {'rent': 'info', 'sale': 'success', 'both': 'primary'}}"/>
                            <field name="agent_id" widget="many2one_avatar_user"/>
                        </footer>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ============================ FORM ============================ -->
    <record id="view_visit_form" model="ir.ui.view">
        <field name="name">real.estate.visit.form</field>
        <field name="model">real.estate.visit</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" type="object" string="Confirm" class="btn-primary" attrs="{'invisible': [('state', '!=', 'scheduled')]}"/>
                    <button name="action_done" type="object" string="Mark Done" class="btn-primary" attrs="{'invisible': [('state', 'not in', ['scheduled', 'confirmed'])]}"/>
                    <button name="action_no_show" type="object" string="No-show" attrs="{'invisible': [('state', 'not in', ['scheduled', 'confirmed'])]}"/>
                    <button name="action_cancel" type="object" string="Cancel" attrs="{'invisible': [('state', 'in', ['done', 'cancelled'])]}"/>
                    <button name="action_reset" type="object" string="Reset" attrs="{'invisible': [('state', 'in', ['scheduled'])]}"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="scheduled,confirmed,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="property_id"/>
                        <h1><field name="property_id"/></h1>
                        <field name="name" readonly="1"/>
                    </div>
                    <group>
                        <group>
                            <field name="contact_id"/>
                            <field name="agent_id" widget="many2one_avatar_user"/>
                            <field name="visit_type"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="date_start"/>
                            <field name="duration" widget="float_time"/>
                            <field name="date_end" readonly="1"/>
                            <field name="interest_level" attrs="{'invisible': [('state', 'not in', ['done', 'no_show'])]}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Internal Notes" name="notes">
                            <field name="notes" placeholder="Logistics, parking, access code..."/>
                        </page>
                        <page string="Feedback" name="feedback" attrs="{'invisible': [('state', 'not in', ['done', 'no_show'])]}">
                            <field name="feedback"
                                   placeholder="What did the visitor think? Next steps?"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- =========================== SEARCH =========================== -->
    <record id="view_visit_search" model="ir.ui.view">
        <field name="name">real.estate.visit.search</field>
        <field name="model">real.estate.visit</field>
        <field name="arch" type="xml">
            <search>
                <field name="property_id"/>
                <field name="contact_id"/>
                <field name="agent_id"/>
                <filter name="my_visits" string="My Visits"
                        domain="[('agent_id', '=', uid)]"/>
                <separator/>
                <filter name="today" string="Today"
                        domain="[('date_start', '&gt;=', context_today().strftime('%Y-%m-%d 00:00:00')),
                                 ('date_start', '&lt;=', context_today().strftime('%Y-%m-%d 23:59:59'))]"/>
                <filter name="this_week" string="This Week"
                        domain="[('date_start', '&gt;=', (context_today() - relativedelta(days=context_today().weekday())).strftime('%Y-%m-%d 00:00:00')),
                                 ('date_start', '&lt;=', (context_today() + relativedelta(days=6 - context_today().weekday())).strftime('%Y-%m-%d 23:59:59'))]"/>
                <filter name="upcoming" string="Upcoming"
                        domain="[('date_start', '&gt;=', context_today().strftime('%Y-%m-%d 00:00:00')),
                                 ('state', 'in', ('scheduled', 'confirmed'))]"/>
                <separator/>
                <filter name="scheduled" string="Scheduled"
                        domain="[('state', '=', 'scheduled')]"/>
                <filter name="confirmed" string="Confirmed"
                        domain="[('state', '=', 'confirmed')]"/>
                <filter name="done" string="Done"
                        domain="[('state', '=', 'done')]"/>
                <group string="Group By">
                    <filter name="group_state" string="Status"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_agent" string="Agent"
                            context="{'group_by': 'agent_id'}"/>
                    <filter name="group_property" string="Property"
                            context="{'group_by': 'property_id'}"/>
                    <filter name="group_date" string="Date"
                            context="{'group_by': 'date_start'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- =========================== ACTION =========================== -->
    <record id="action_visit" model="ir.actions.act_window">
        <field name="name">Visits</field>
        <field name="res_model">real.estate.visit</field>
        <field name="view_mode">calendar,list,kanban,form</field>
        <field name="search_view_id" ref="view_visit_search"/>
        <field name="context">{'search_default_upcoming': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Schedule your first visit</p>
            <p>Track property viewings with prospective tenants and buyers.</p>
        </field>
    </record>

</odoo>
