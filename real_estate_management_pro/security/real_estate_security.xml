<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Application category -->
    <record id="module_category_real_estate" model="ir.module.category">
        <field name="name">Real Estate</field>
        <field name="description">Real Estate Management</field>
        <field name="sequence">20</field>
    </record>

    <!-- Odoo 19: groups are grouped through a res.groups.privilege record
         (res.groups.category_id was removed in favour of privilege_id). -->
    <record id="privilege_real_estate" model="res.groups.privilege">
        <field name="name">Real Estate</field>
        <field name="category_id" ref="module_category_real_estate"/>
        <field name="sequence">20</field>
    </record>

    <!-- Groups -->
    <record id="group_real_estate_user" model="res.groups">
        <field name="name">Agent</field>
        <field name="privilege_id" ref="privilege_real_estate"/>
        <field name="comment">Day-to-day use: properties, contracts, tickets and renovations.</field>
    </record>

    <record id="group_real_estate_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="privilege_real_estate"/>
        <field name="implied_ids" eval="[(4, ref('group_real_estate_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
        <field name="comment">Full access, including configuration and deletion.</field>
    </record>

    <!-- Multi-company record rules -->
    <record id="rule_property_company" model="ir.rule">
        <field name="name">Property: multi-company</field>
        <field name="model_id" ref="model_real_estate_property"/>
        <field name="global" eval="True"/>
        <field name="domain_force">
            ['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]
        </field>
    </record>

    <record id="rule_contract_company" model="ir.rule">
        <field name="name">Contract: multi-company</field>
        <field name="model_id" ref="model_real_estate_contract"/>
        <field name="global" eval="True"/>
        <field name="domain_force">
            ['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]
        </field>
    </record>

</odoo>
